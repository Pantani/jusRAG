APP_ENV=local
APP_NAME=jus-rag-brasil
LOG_LEVEL=INFO

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jus_rag
POSTGRES_USER=jus
POSTGRES_PASSWORD=jus

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_LEGAL_CHUNKS=legal_chunks

REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Provider selection: 'fake' runs offline/demo deterministically without OPENAI_API_KEY
EMBEDDING_PROVIDER=openai
LLM_PROVIDER=openai

ENABLE_OPENSEARCH=false
OPENSEARCH_URL=http://opensearch:9200

STORE_RUN_LOGS=true
ANONYMIZE_RUN_LOGS=true

OLLAMA_BASE_URL=http://ollama:11434
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
OLLAMA_CHAT_MODEL=llama3.1:8b